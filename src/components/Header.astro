---
// Header component with navigation
---

<header class="sticky top-0 z-50 bg-white border-b-2 border-[#EDF2FA]">
  <nav aria-label="Main" class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo / Brand -->
      <div class="flex-shrink-0">
        <a href="/" class="flex items-center gap-2.5 text-[#1B3A5C] font-serif font-bold text-xl no-underline" style="text-decoration: none;">
          <div class="w-9 h-9 bg-[#4B8BD4] rounded-[10px] flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
              <polyline points="14,2 14,8 20,8"/>
            </svg>
          </div>
          WorkInPrivate
        </a>
      </div>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center">
        <ul class="flex items-center gap-7 list-none mr-6">
          <li>
            <a href="/" class="text-[#5A6474] hover:text-[#4B8BD4] font-semibold text-base transition-colors no-underline" style="text-decoration: none;">
              Home
            </a>
          </li>
          <li>
            <a href="/pricing" class="text-[#5A6474] hover:text-[#4B8BD4] font-semibold text-base transition-colors no-underline" style="text-decoration: none;">
              Pricing
            </a>
          </li>
          <li>
            <a href="/faq" class="text-[#5A6474] hover:text-[#4B8BD4] font-semibold text-base transition-colors no-underline" style="text-decoration: none;">
              FAQ
            </a>
          </li>
        </ul>
        <a href="/pricing" class="inline-flex items-center px-5 py-2.5 text-sm font-bold rounded-[10px] text-white bg-[#4B8BD4] hover:bg-[#2E6BB5] transition-colors shadow-sm no-underline" style="text-decoration: none; box-shadow: 0 2px 8px rgba(75,139,212,0.3);">
          Get Started
        </a>
      </div>

      <!-- Mobile menu button -->
      <div class="md:hidden">
        <button
          type="button"
          class="mobile-menu-button inline-flex items-center justify-center p-2 rounded-md text-[#5A6474] hover:text-[#4B8BD4] hover:bg-[#EDF2FA] focus:outline-none focus:ring-2 focus:ring-inset focus:ring-[#4B8BD4]"
          aria-expanded="false"
          aria-label="Main menu"
        >
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile Navigation Menu -->
    <div class="mobile-menu hidden md:hidden pb-3 pt-2 bg-white border-t border-[#EDF2FA]">
      <div class="flex flex-col space-y-1">
        <a href="/" class="text-[#5A6474] hover:text-[#4B8BD4] hover:bg-[#EDF2FA] block px-3 py-2 rounded-md text-base font-semibold no-underline" style="text-decoration: none;">
          Home
        </a>
        <a href="/pricing" class="text-[#5A6474] hover:text-[#4B8BD4] hover:bg-[#EDF2FA] block px-3 py-2 rounded-md text-base font-semibold no-underline" style="text-decoration: none;">
          Pricing
        </a>
        <a href="/faq" class="text-[#5A6474] hover:text-[#4B8BD4] hover:bg-[#EDF2FA] block px-3 py-2 rounded-md text-base font-semibold no-underline" style="text-decoration: none;">
          FAQ
        </a>
        <a href="/pricing" class="mt-2 text-center text-white bg-[#4B8BD4] hover:bg-[#2E6BB5] block px-3 py-2.5 rounded-[10px] text-base font-bold transition-colors no-underline" style="text-decoration: none;">
          Get Started
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  // Mobile menu toggle
  document.addEventListener('DOMContentLoaded', () => {
    const menuButton = document.querySelector('.mobile-menu-button');
    const mobileMenu = document.querySelector('.mobile-menu');

    if (menuButton && mobileMenu) {
      menuButton.addEventListener('click', () => {
        const isHidden = mobileMenu.classList.contains('hidden');
        mobileMenu.classList.toggle('hidden');
        menuButton.setAttribute('aria-expanded', isHidden ? 'true' : 'false');
      });
    }
  });
</script>

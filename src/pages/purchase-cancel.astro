---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Purchase Cancelled - WorkInPrivate" description="Your WorkInPrivate purchase was cancelled. No charges were made. Return to pricing when you're ready.">

  <!-- Cancel Hero -->
  <section class="py-16 sm:py-20 bg-gradient-to-b from-white to-[#F7F9FC]">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-xl mx-auto text-center">

        <!-- Cancel icon -->
        <div class="w-20 h-20 bg-[#F7F9FC] rounded-full flex items-center justify-center mx-auto mb-8 border-2 border-[#E2E8F0]">
          <svg class="w-10 h-10 text-[#8A9AB5]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </div>

        <h1 class="font-serif text-4xl sm:text-5xl font-bold text-[#1B3A5C] mb-4">Purchase Cancelled</h1>
        <p class="text-xl text-[#5A6474] mb-4">
          No problem — no charge was made to your account.
        </p>
        <p class="text-[#8A9AB5] mb-12">
          If you ran into an issue or have questions before purchasing, we're happy to help.
        </p>

        <!-- Actions -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center mb-12">
          <a href="/pricing" class="px-8 py-4 text-lg font-bold rounded-[10px] text-white bg-[#4B8BD4] hover:bg-[#2E6BB5] transition-all no-underline" style="text-decoration: none; box-shadow: 0 2px 8px rgba(75,139,212,0.3);">
            Back to Pricing
          </a>
          <a href="/faq" class="px-8 py-4 text-lg font-semibold rounded-[10px] text-[#1B3A5C] border-2 border-[#E2E8F0] hover:border-[#D4E3F5] transition-colors no-underline" style="text-decoration: none;">
            Read the FAQ
          </a>
        </div>

        <!-- Reassurance -->
        <div class="bg-[#F0FFF4] rounded-xl border-2 border-[#C6F6D5] p-6 text-left space-y-4">
          <h3 class="font-bold text-[#1B3A5C]">Things worth knowing</h3>
          <ul class="space-y-3">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-[#38A169] mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              <span class="text-[#5A6474] text-sm">One-time payment — no subscription, no recurring charges</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-[#38A169] mt-0.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              <span class="text-[#5A6474] text-sm">100% local — your content never leaves your machine</span>
            </li>
          </ul>
        </div>

        <p class="text-[#8A9AB5] text-sm mt-8">
          Have a question?
          <a href="mailto:support@workinprivate.com" class="text-[#4B8BD4] hover:underline">support@workinprivate.com</a>
        </p>

      </div>
    </div>
  </section>

</BaseLayout>

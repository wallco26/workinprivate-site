---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Download WorkInPrivate" description="Purchase WorkInPrivate to get instant download access for Windows, macOS, or Linux.">

  <!-- Hero -->
  <section class="py-16 sm:py-20 bg-gradient-to-b from-white to-[#F7F9FC]">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-serif text-4xl sm:text-5xl font-bold text-[#1B3A5C] mb-4">Download WorkInPrivate</h1>
      <p class="text-xl text-[#5A6474] max-w-2xl mx-auto mb-8">Purchase WorkInPrivate to get instant download access for Windows, macOS, and Linux.</p>
      <a href="https://buy.stripe.com/4gM9ATfo15Li8eX9PDaR20g" class="inline-flex items-center gap-2 px-8 py-4 rounded-[10px] text-white font-bold text-lg bg-[#4B8BD4] hover:bg-[#2E6BB5] transition-all no-underline" style="text-decoration: none; box-shadow: 0 2px 8px rgba(75,139,212,0.3);">
        Buy Now — $39
      </a>
      <p class="text-[#8A9AB5] text-sm mt-4">One-time payment. Download links provided immediately after purchase.</p>
    </div>
  </section>

  <!-- System Requirements -->
  <section class="py-16 bg-white border-t-2 border-[#E2E8F0]">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto">
        <h2 class="font-serif text-2xl font-bold text-[#1B3A5C] mb-6 text-center">System Requirements</h2>
        <div class="bg-[#F7F9FC] border-2 border-[#E2E8F0] rounded-xl p-6">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
            <div>
              <div class="font-bold text-[#1B3A5C] mb-1">Operating System</div>
              <div class="text-[#5A6474]">Windows 10+, macOS 12+, or Linux</div>
            </div>
            <div>
              <div class="font-bold text-[#1B3A5C] mb-1">RAM (Memory)</div>
              <div class="text-[#5A6474]">8 GB minimum, 16 GB recommended</div>
            </div>
            <div>
              <div class="font-bold text-[#1B3A5C] mb-1">Disk Space</div>
              <div class="text-[#5A6474]">5 GB free for the app + AI models</div>
            </div>
            <div>
              <div class="font-bold text-[#1B3A5C] mb-1">GPU (optional)</div>
              <div class="text-[#5A6474]">NVIDIA or Apple Silicon for faster responses</div>
            </div>
          </div>
          <p class="text-xs text-[#8A9AB5] mt-4">The app automatically detects your hardware and recommends the best AI model for your computer.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Already purchased? -->
  <section class="py-12 bg-[#F7F9FC] border-t-2 border-[#E2E8F0]">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-[#5A6474] text-sm">
        Already purchased? Check your email for the download links, or <a href="mailto:support@workinprivate.com" class="text-[#4B8BD4] hover:underline">contact support</a> for help.
      </p>
    </div>
  </section>

</BaseLayout>

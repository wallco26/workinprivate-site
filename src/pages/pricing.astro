                class="w-full px-4 py-3 rounded-lg bg-white border-2 border-[#E2E8F0] text-[#1B3A5C] text-sm focus:outline-none focus:border-[#4B8BD4] cursor-pointer"
              >
                <option value="seo_writer">Blog Writer — articles for your blog or website</option>
                <option value="tech_docs">Tech Docs — technical guides and documentation</option>
                <option value="academic">Academic — research papers and essays</option>
                <option value="small_business">Small Business — marketing and business content</option>
                <option value="legal">Legal — legal topics and compliance</option>
                <option value="healthcare">Healthcare — health and wellness articles</option>
                <option value="finance">Finance — money and investing articles</option>
              </select>
            </div>

            <button
              id="base-buy-btn"
              type="button"
              class="block w-full text-center px-8 py-4 text-lg font-bold rounded-xl text-white bg-[#4B8BD4] hover:bg-[#2E6BB5] transition-colors no-underline" style="text-decoration: none; box-shadow: 0 2px 8px rgba(75,139,212,0.3);"
            >
              Get Started &mdash; $29
            </button>
          </div>
        </div>

        <!-- Complete Bundle -->
        <div class="rounded-2xl border-[3px] border-[#4B8BD4] overflow-hidden relative bg-white" style="box-shadow: 0 8px 32px rgba(75,139,212,0.12);">
          <div class="absolute -top-0 right-4">
            <span class="inline-block bg-[#38A169] text-white text-xs font-bold px-3 py-1 rounded-b-lg uppercase tracking-wide">Best Value</span>

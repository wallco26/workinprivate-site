            <span class="text-xs font-bold text-[#4B8BD4] uppercase tracking-widest">Complete Bundle</span>
          </div>
          <div class="px-8 py-10 text-center">
            <h2 class="font-serif text-2xl font-bold text-[#1B3A5C] mb-2">All 7 Writing Modules</h2>
            <p class="text-[#5A6474] mb-6">The app + every module included</p>
            <div class="mb-2" id="bundle-price-display">
              <span class="font-serif font-bold text-[#4B8BD4]" id="bundle-price" style="font-size: 3.5rem; line-height: 1;"><sup style="font-size: 1.4rem; vertical-align: super;">$</sup>99</span>
              <div class="text-[#38A169] font-bold text-base mt-1">one-time payment</div>
            </div>
            <p class="text-sm text-[#38A169] font-semibold mb-6" id="bundle-savings">Save $63 vs. buying separately ($162)</p>
            <ul class="text-left space-y-3 mb-8 list-none p-0 m-0">
              <li class="flex items-start">
                <svg class="w-5 h-5 text-[#38A169] mt-0.5 mr-3 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                <span class="text-[#2D3748]">WorkInPrivate desktop app</span>
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-[#38A169] mt-0.5 mr-3 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                <span class="text-[#1B3A5C] font-semibold">All 7 writing modules included</span>
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-[#38A169] mt-0.5 mr-3 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                <span class="text-[#2D3748]">Works on Windows, Mac, and Linux</span>
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-[#38A169] mt-0.5 mr-3 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                <span class="text-[#2D3748]">Save as Markdown, Text, HTML, or PDF</span>
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-[#38A169] mt-0.5 mr-3 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                <span class="text-[#2D3748]">100% private — your writing never leaves your computer</span>
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-[#38A169] mt-0.5 mr-3 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                <span class="text-[#2D3748]">Future module updates included</span>
              </li>
            </ul>
            <button
              id="bundle-buy-btn"
              type="button"
              class="block w-full text-center px-8 py-4 text-lg font-bold rounded-xl text-white bg-[#4B8BD4] hover:bg-[#2E6BB5] transition-all no-underline" style="text-decoration: none; box-shadow: 0 4px 16px rgba(75,139,212,0.3);"
            >
              Get Complete Bundle &mdash; $99
            </button>
          </div>
        </div>
      </div>

      <!-- Money-back guarantee -->
      <div class="max-w-5xl mx-auto mt-8 text-center">
        <div class="inline-flex items-center gap-2.5 bg-[#F0FFF4] border-2 border-[#C6F6D5] rounded-xl px-5 py-3">
          <svg class="w-5 h-5 text-[#38A169] flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <span class="text-[#2D3748] text-sm font-semibold">30-day money-back guarantee on all purchases — no questions asked.</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Add-on Modules -->
  <section class="py-16 bg-white border-t-2 border-[#E2E8F0]">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <div class="text-xs font-bold uppercase tracking-widest text-[#4B8BD4] mb-3">Expand Your Toolkit</div>
        <h2 class="font-serif text-3xl sm:text-4xl font-bold text-[#1B3A5C] mb-4 leading-tight">Add-on Writing Modules</h2>
        <p class="text-lg text-[#5A6474] max-w-2xl mx-auto">Already have the base package? Add more writing modules for <span class="font-bold text-[#4B8BD4]">$19 each</span>.</p>
      </div>
      <div class="max-w-5xl mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">

        {MODULES.map((mod, i) => (
          <div class={`bg-[#F7F9FC] border-2 border-[#E2E8F0] rounded-xl p-6 flex flex-col hover:border-[#D4E3F5] transition-colors${i === MODULES.length - 1 ? ' sm:col-span-2 lg:col-span-1' : ''}`}>
            <div class="w-12 h-12 rounded-xl bg-[#EDF2FA] flex items-center justify-center flex-shrink-0 text-2xl mb-3">
              {mod.emoji}
            </div>
            <h3 class="font-bold text-[#1B3A5C] text-base mb-2">{mod.name}</h3>
            <p class="text-[#5A6474] text-sm leading-relaxed flex-grow mb-5">{mod.desc}</p>
            <div class="flex items-center justify-between">
              <span class="text-2xl font-bold text-[#1B3A5C] addon-price" data-module={mod.id}>$19</span>
              <button
                type="button"
                data-product-type="addon"
                data-module={mod.id}
                class="addon-buy-btn inline-flex items-center px-5 py-2.5 text-sm font-bold rounded-lg text-[#4B8BD4] border-2 border-[#D4E3F5] hover:bg-[#EDF2FA] hover:border-[#4B8BD4] transition-colors"
              >
                Add Module
              </button>
            </div>
          </div>
        ))}

      </div>
    </div>
  </section>

  <!-- System Requirements -->
  <section class="py-16 bg-[#F7F9FC] border-t-2 border-[#E2E8F0]">

          <p class="text-lg text-[#5A6474]">WorkInPrivate runs on your own computer. Here's what you'll need to get started.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <!-- Requirements -->
          <div class="bg-white rounded-2xl p-8 border-2 border-[#E2E8F0]">
            <h3 class="font-serif text-lg font-bold text-[#1B3A5C] mb-4">Hardware</h3>
            <ul class="space-y-3 list-none p-0 m-0">
              <li class="flex items-start">
                <svg class="w-5 h-5 text-[#38A169] mt-0.5 mr-3 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                <div>
                  <span class="font-bold text-[#1B3A5C]">Memory (RAM):</span>
                  <span class="text-[#5A6474]"> 8 GB minimum, 16 GB or more is ideal</span>
                </div>
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-[#38A169] mt-0.5 mr-3 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                <div>
                  <span class="font-bold text-[#1B3A5C]">Graphics card:</span>
                  <span class="text-[#5A6474]"> Optional, but makes writing faster</span>
                </div>
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-[#38A169] mt-0.5 mr-3 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                <div>
                  <span class="font-bold text-[#1B3A5C]">Hard drive space:</span>
                  <span class="text-[#5A6474]"> About 5 GB for the app and AI models</span>
                </div>
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-[#38A169] mt-0.5 mr-3 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                <div>
                  <span class="font-bold text-[#1B3A5C]">Internet:</span>
                  <span class="text-[#5A6474]"> Only needed once during first-time setup</span>
                </div>
              </li>
            </ul>
          </div>
          <!-- Platform Availability -->
          <div class="bg-white rounded-2xl p-8 border-2 border-[#E2E8F0]">
            <h3 class="font-serif text-lg font-bold text-[#1B3A5C] mb-4">Works On</h3>
            <ul class="space-y-3 list-none p-0 m-0">
              <li class="flex items-start">
                <svg class="w-5 h-5 text-[#38A169] mt-0.5 mr-3 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                <div>
                  <span class="font-bold text-[#1B3A5C]">Windows</span>

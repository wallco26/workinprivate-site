---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Pricing - WorkInPrivate" description="Get WorkInPrivate for $39 one-time. No subscriptions, no API costs, no usage limits. Your private AI chatbot, forever.">

  <!-- Pricing Hero -->
  <section class="py-16 sm:py-20 bg-gradient-to-b from-white to-[#F7F9FC]">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="inline-flex items-center gap-2 px-4 py-2.5 rounded-full bg-[#F0FFF4] text-[#38A169] text-sm font-bold mb-5 border border-[#C6F6D5]">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
        One-time payment — no subscriptions
      </div>
      <h1 class="font-serif text-4xl sm:text-5xl font-bold text-[#1B3A5C] mb-5 leading-tight">Simple, Honest Pricing</h1>
      <p class="text-xl text-[#5A6474] max-w-2xl mx-auto leading-relaxed">One app. One price. No monthly bills, no usage limits, no surprises.</p>
    </div>
  </section>

  <!-- Pricing Card -->
  <section class="py-16 bg-[#F7F9FC]">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-lg mx-auto">
        <div class="bg-white border-2 border-[#D4E3F5] rounded-2xl overflow-hidden" style="box-shadow: 0 8px 32px rgba(27,58,92,0.10);">
          <!-- Card Header -->
          <div class="bg-[#4B8BD4] px-8 py-8 text-center text-white">
            <h2 class="font-serif text-2xl font-bold mb-2">WorkInPrivate</h2>
            <p class="text-[#D4E3F5] text-sm">Your private AI chatbot</p>
            <div class="mt-4">
              <span class="text-5xl font-bold">$39</span>
              <span class="text-[#D4E3F5] text-lg ml-2">one-time</span>
            </div>
          </div>

          <!-- Card Body -->
          <div class="px-8 py-8">
            <ul class="space-y-4 mb-8">
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-[#38A169] flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                <span class="text-[#1B3A5C]"><strong>Full chat interface</strong> — ask anything, write anything</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-[#38A169] flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                <span class="text-[#1B3A5C]"><strong>File analysis</strong> — PDFs, Word docs, images, code</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-[#38A169] flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                <span class="text-[#1B3A5C]"><strong>Conversation history</strong> — search past chats</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-[#38A169] flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                <span class="text-[#1B3A5C]"><strong>Multiple AI models</strong> — choose the best for your needs</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-[#38A169] flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                <span class="text-[#1B3A5C]"><strong>Dark & light themes</strong> — comfortable day or night</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-[#38A169] flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                <span class="text-[#1B3A5C]"><strong>Works offline</strong> — no internet needed after setup</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-[#38A169] flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                <span class="text-[#1B3A5C]"><strong>Windows, macOS, Linux</strong> — all platforms included</span>
              </li>
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-[#38A169] flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                <span class="text-[#1B3A5C]"><strong>Free updates</strong> — new features as they come</span>
              </li>
            </ul>

            <a href="https://buy.stripe.com/4gM9ATfo15Li8eX9PDaR20g" class="block w-full text-center px-8 py-4 rounded-[10px] text-white font-bold text-lg bg-[#4B8BD4] hover:bg-[#2E6BB5] transition-all no-underline" style="text-decoration: none; box-shadow: 0 2px 8px rgba(75,139,212,0.3);">
              Buy Now — $39
            </a>

            <p class="text-center text-[#8A9AB5] text-sm mt-4">30-day money-back guarantee</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Cost Comparison -->
  <section class="py-16 bg-white border-t-2 border-[#E2E8F0]">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="font-serif text-3xl font-bold text-[#1B3A5C] mb-4">Stop Paying Monthly</h2>
        <p class="text-lg text-[#5A6474]">Here's what AI chatbot subscriptions really cost over time:</p>
      </div>
      <div class="max-w-3xl mx-auto grid grid-cols-1 sm:grid-cols-3 gap-6 text-center">
        <div class="bg-[#F7F9FC] border-2 border-[#E2E8F0] rounded-xl p-6">
          <div class="text-3xl font-bold text-[#4B8BD4] mb-2">$39</div>
          <div class="text-sm text-[#5A6474] font-semibold">WorkInPrivate</div>
          <div class="text-xs text-[#8A9AB5] mt-1">One-time, forever</div>
        </div>
        <div class="bg-[#F7F9FC] border-2 border-[#E2E8F0] rounded-xl p-6">
          <div class="text-3xl font-bold text-[#E53E3E] mb-2">$240</div>
          <div class="text-sm text-[#5A6474] font-semibold">ChatGPT Plus</div>
          <div class="text-xs text-[#8A9AB5] mt-1">$20/mo for 1 year</div>
        </div>
        <div class="bg-[#F7F9FC] border-2 border-[#E2E8F0] rounded-xl p-6">
          <div class="text-3xl font-bold text-[#E53E3E] mb-2">$240</div>
          <div class="text-sm text-[#5A6474] font-semibold">Claude Pro</div>
          <div class="text-xs text-[#8A9AB5] mt-1">$20/mo for 1 year</div>
        </div>
      </div>
    </div>
  </section>

  <!-- System Requirements -->
  <section class="py-16 bg-[#F7F9FC] border-t-2 border-[#E2E8F0]">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto">
        <h2 class="font-serif text-2xl font-bold text-[#1B3A5C] mb-6 text-center">System Requirements</h2>
        <div class="bg-white border-2 border-[#E2E8F0] rounded-xl p-6">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
            <div>
              <div class="font-bold text-[#1B3A5C] mb-1">Operating System</div>
              <div class="text-[#5A6474]">Windows 10+, macOS 12+, or Linux</div>
            </div>
            <div>
              <div class="font-bold text-[#1B3A5C] mb-1">RAM (Memory)</div>
              <div class="text-[#5A6474]">8 GB minimum, 16 GB recommended</div>
            </div>
            <div>
              <div class="font-bold text-[#1B3A5C] mb-1">Disk Space</div>
              <div class="text-[#5A6474]">5 GB free for the app + AI models</div>
            </div>
            <div>
              <div class="font-bold text-[#1B3A5C] mb-1">GPU (optional)</div>
              <div class="text-[#5A6474]">NVIDIA or Apple Silicon for faster responses</div>
            </div>
          </div>
          <p class="text-xs text-[#8A9AB5] mt-4">The app automatically detects your hardware and recommends the best AI model for your computer.</p>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

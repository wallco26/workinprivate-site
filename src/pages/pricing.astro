            <span class="text-xs font-bold text-[#5A6474] uppercase tracking-widest">Starter</span>
          </div>
          <div class="px-8 py-10 text-center">
            <h2 class="font-serif text-2xl font-bold text-[#1B3A5C] mb-2">Base Package</h2>
            <p class="text-[#5A6474] mb-6">The app + 1 writing module of your choice</p>
            <div class="mb-6" id="base-price-display">
              <span class="font-serif font-bold text-[#4B8BD4]" id="base-price" style="font-size: 3.5rem; line-height: 1;"><sup style="font-size: 1.4rem; vertical-align: super;">$</sup>29</span>
              <div class="text-[#38A169] font-bold text-base mt-1">one-time payment</div>
            </div>
            <ul class="text-left space-y-3 mb-6 list-none p-0 m-0">
              <li class="flex items-start">
                <svg class="w-5 h-5 text-[#38A169] mt-0.5 mr-3 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                <span class="text-[#2D3748]">WorkInPrivate desktop app</span>
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-[#38A169] mt-0.5 mr-3 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                <span class="text-[#2D3748]">1 writing module of your choice</span>
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-[#38A169] mt-0.5 mr-3 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                <span class="text-[#2D3748]">Works on Windows, Mac, and Linux</span>
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-[#38A169] mt-0.5 mr-3 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                <span class="text-[#2D3748]">Save as Markdown, Text, HTML, or PDF</span>
              </li>
              <li class="flex items-start">
                <svg class="w-5 h-5 text-[#38A169] mt-0.5 mr-3 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
                <span class="text-[#2D3748]">100% private — your writing never leaves your computer</span>
              </li>
            </ul>

            <!-- Module selector -->
            <div class="mb-6 text-left">
              <label for="base-module-select" class="block text-sm font-bold text-[#1B3A5C] mb-2">
                Choose your writing module:

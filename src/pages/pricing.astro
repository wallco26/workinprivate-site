---
import BaseLayout from '../layouts/BaseLayout.astro';

// Module display names for add-on cards
const MODULES = [
  { id: 'seo_writer', name: 'Blog Writer', desc: 'Write SEO-optimized blog articles that help people find your website through Google searches.', emoji: '✍️' },
  { id: 'tech_docs', name: 'Tech Docs', desc: 'Create clear technical documentation, how-to guides, and software references.', emoji: '💻' },
  { id: 'academic', name: 'Academic', desc: 'Generate research-style papers and educational articles with proper citations and formatting.', emoji: '📚' },
  { id: 'finance', name: 'Finance', desc: 'Write articles about money management, investing basics, and personal finance tips.', emoji: '💰' },
  { id: 'healthcare', name: 'Healthcare', desc: 'Create health and wellness articles, patient guides, and medical information content.', emoji: '🩺' },
  { id: 'legal', name: 'Legal', desc: 'Write articles about legal topics, policies, and regulatory information for everyday readers.', emoji: '⚖️' },
  { id: 'small_business', name: 'Small Business', desc: 'Marketing copy, announcements, and content tailored for small businesses and side projects.', emoji: '💼' },
];

const SUPABASE_URL = 'https://peungwkkkqorgzxfhyaa.supabase.co';
const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InBldW5nd2tra3Fvcmd6eGZoeWFhIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzE1NTI3MzgsImV4cCI6MjA4NzEyODczOH0.9fjWeAXZbOefOXn3tJFC5Qj9VtEdBY50EOPwQbxfSbs';
---

<BaseLayout title="Pricing - WorkInPrivate" description="Get WorkInPrivate starting at $29 for the base package with one module. Add specialized modules for $19 each. No subscriptions, no API costs — pay once, own it forever.">

  <!-- Pricing Hero -->
  <section class="py-16 sm:py-20 bg-gradient-to-b from-white to-[#F7F9FC]">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="inline-flex items-center gap-2 px-4 py-2.5 rounded-full bg-[#F0FFF4] text-[#38A169] text-sm font-bold mb-5 border border-[#C6F6D5]">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
        One-time payment — no subscriptions
      </div>
      <h1 class="font-serif text-4xl sm:text-5xl font-bold text-[#1B3A5C] mb-5 leading-tight">Simple, Honest Pricing</h1>
      <p class="text-xl text-[#5A6474] max-w-2xl mx-auto leading-relaxed">Pay once and it's yours forever. No monthly fees, no hidden costs, no surprises on your credit card statement.</p>
    </div>
  </section>

  <!-- Promo Code Bar -->
  <section class="bg-[#F7F9FC] pt-10 pb-0 border-t-2 border-[#E2E8F0]">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-md mx-auto">
        <label for="promo-input" class="block text-sm font-semibold text-[#5A6474] mb-2 text-center">Have a promo code?</label>
        <div class="flex gap-2">
          <input
            id="promo-input"
            type="text"
            placeholder="Enter code"
            class="flex-1 px-4 py-3 rounded-lg bg-white border-2 border-[#E2E8F0] text-[#1B3A5C] font-semibold text-sm focus:outline-none focus:border-[#4B8BD4] placeholder-[#8A9AB5] uppercase"
          />
          <button
            id="promo-apply-btn"
            type="button"
            class="px-6 py-3 rounded-lg text-sm font-bold bg-[#EDF2FA] text-[#4B8BD4] border-2 border-[#D4E3F5] hover:bg-[#D4E3F5] transition-colors"
          >
            Apply
          </button>
        </div>
        <div id="promo-result" class="mt-3 text-sm text-center hidden"></div>
      </div>
    </div>
  </section>

  <!-- Package Deal Card (shown when package promo applied) -->
  <section id="package-deal-section" class="bg-[#F7F9FC] pt-8 pb-0 hidden">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto rounded-2xl border-[3px] border-[#4B8BD4] overflow-hidden bg-white relative" style="box-shadow: 0 8px 32px rgba(75,139,212,0.12);">
        <div class="absolute -top-0 right-4">
          <span class="inline-block bg-[#38A169] text-white text-xs font-bold px-3 py-1 rounded-b-lg uppercase tracking-wide">Special Deal</span>
        </div>
        <div class="bg-[#EDF2FA] px-8 py-4 text-center border-b-2 border-[#D4E3F5]">
          <span id="package-deal-title" class="text-sm font-bold text-[#4B8BD4] uppercase tracking-wide">Special Package</span>
        </div>
        <div class="px-8 py-10 text-center">
          <p id="package-deal-desc" class="text-[#5A6474] mb-4"></p>
          <div class="mb-4">
            <span id="package-deal-price" class="font-serif text-5xl font-bold text-[#4B8BD4]"></span>
            <span class="text-[#8A9AB5] ml-2">one-time</span>
          </div>
          <p id="package-deal-modules" class="text-sm text-[#5A6474] mb-6"></p>
          <button
            id="package-deal-btn"
            type="button"
            class="inline-block w-full max-w-sm px-8 py-4 text-lg font-bold rounded-xl text-white bg-[#4B8BD4] hover:bg-[#2E6BB5] transition-colors no-underline" style="text-decoration: none; box-shadow: 0 2px 8px rgba(75,139,212,0.3);"
          >
            Get This Deal
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing Cards -->
  <section class="py-16 bg-[#F7F9FC]">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8 items-start">

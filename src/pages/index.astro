---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="WorkInPrivate — Explore AI Writing From the Comfort of Home" description="WorkInPrivate is a simple program that helps you write blog posts, articles, and guides using artificial intelligence. It runs on your own computer, so your writing stays completely private.">

  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "WorkInPrivate",
    "description": "A simple AI writing program that runs on your own computer. No monthly fees, no cloud, complete privacy.",
    "url": "https://www.workinprivate.com",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Windows, macOS, Linux",
    "offers": {
      "@type": "Offer",
      "price": "29.00",
      "priceCurrency": "USD",
      "availability": "https://schema.org/InStock"
    },
    "featureList": [
      "Runs 100% on your computer",
      "7 specialized writing modules",
      "One-time purchase — no subscription",
      "No internet required after setup",
      "Complete privacy — your writing never leaves your computer",
      "Works on Windows, macOS, and Linux"
    ]
  })} />

  <!-- Hero Section -->
  <section class="py-20 bg-gradient-to-b from-white to-[#F7F9FC]">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <!-- Text content -->
        <div>
          <div class="inline-flex items-center gap-2 px-4 py-2.5 rounded-lg bg-[#F0FFF4] text-[#38A169] text-sm font-bold mb-5 border border-[#C6F6D5]" style="animation: fadeUp 0.5s ease both;">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
            Easy to use — no tech experience needed
          </div>
          <h1 class="font-serif text-4xl sm:text-5xl font-bold text-[#1B3A5C] mb-5 leading-tight" style="animation: fadeUp 0.5s ease 0.1s both;">
            Write Articles With AI,<br /><span class="text-[#4B8BD4]">Right From Your Computer</span>
          </h1>
          <p class="text-lg text-[#5A6474] mb-8 max-w-lg leading-relaxed" style="animation: fadeUp 0.5s ease 0.2s both;">
            WorkInPrivate is a simple program that helps you write blog posts, articles, and guides using artificial intelligence. It runs on your own computer — your writing never leaves your machine.
          </p>
          <div class="flex flex-wrap gap-4 mb-7" style="animation: fadeUp 0.5s ease 0.3s both;">
            <a href="/pricing" class="inline-flex items-center gap-2.5 px-8 py-4 rounded-[10px] text-white font-bold text-lg bg-[#4B8BD4] hover:bg-[#2E6BB5] transition-all no-underline" style="text-decoration: none; box-shadow: 0 2px 8px rgba(75,139,212,0.3);">
              Try It — Just $29
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
            <a href="#how-it-works" class="inline-flex items-center gap-2 px-8 py-4 rounded-[10px] text-[#2E6BB5] font-bold text-lg bg-[#EDF2FA] hover:bg-[#D4E3F5] border-2 border-[#D4E3F5] hover:border-[#4B8BD4] transition-all no-underline" style="text-decoration: none;">
              Learn How It Works
            </a>
          </div>
          <div class="flex items-center gap-2.5 bg-[#FEFCBF] text-yellow-900 px-4 py-3 rounded-lg border border-[#ECC94B] text-sm font-semibold" style="animation: fadeUp 0.5s ease 0.4s both;">
            <svg class="w-5 h-5 text-[#D69E2E] flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <strong>30-day money-back guarantee — if you don't love it, get a full refund. No hassle.</strong>
          </div>
        </div>
        <!-- Hero illustration -->
        <div class="max-w-md mx-auto w-full">
          <div class="bg-[#EDF2FA] rounded-2xl p-10 border-2 border-[#D4E3F5] text-center">
            <div class="w-24 h-24 bg-white rounded-2xl flex items-center justify-center mx-auto mb-6 border border-[#E2E8F0]" style="box-shadow: 0 4px 20px rgba(0,0,0,0.06);">
              <svg class="w-12 h-12 text-[#4B8BD4]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                <polyline points="14,2 14,8 20,8"/>
                <line x1="16" y1="13" x2="8" y2="13"/>
                <line x1="16" y1="17" x2="8" y2="17"/>
                <line x1="10" y1="9" x2="8" y2="9"/>
              </svg>
            </div>
            <div class="font-serif font-bold text-[#1B3A5C] text-lg mb-2">Your Article Is Ready!</div>
            <div class="text-[#5A6474] text-base mb-5">"Best Garden Tips for Spring 2026"</div>
            <div class="text-left max-w-[280px] mx-auto space-y-2 mb-5">
              <div class="h-2.5 rounded-full bg-[#D4E3F5] opacity-70" style="width: 90%;"></div>
              <div class="h-2.5 rounded-full bg-[#D4E3F5] opacity-70" style="width: 75%;"></div>
              <div class="h-2.5 rounded-full bg-[#D4E3F5] opacity-70" style="width: 85%;"></div>
              <div class="h-2.5 rounded-full bg-[#D4E3F5] opacity-70" style="width: 60%;"></div>
              <div class="h-2.5 rounded-full bg-[#D4E3F5] opacity-70" style="width: 80%;"></div>
            </div>
            <div class="flex items-center justify-center gap-2 text-[#38A169] font-semibold text-sm">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6L9 17l-5-5"/></svg>
              2,100 words &bull; Easy to find online &bull; Ready to publish
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What Is This Section -->
  <section class="py-20 bg-[#EDF2FA] border-t-2 border-b-2 border-[#D4E3F5]">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center">
        <div class="text-xs font-bold uppercase tracking-widest text-[#4B8BD4] mb-3">What Is This?</div>
        <h2 class="font-serif text-3xl sm:text-4xl font-bold text-[#1B3A5C] mb-5 leading-tight">A Writing Helper That Runs on Your Computer</h2>
        <p class="text-lg text-[#5A6474] leading-relaxed">
          You've probably heard about ChatGPT and AI writing tools. They're powerful, but they cost $20 or more every month and send your writing to remote servers. WorkInPrivate gives you the same writing power, but it runs right on your own computer. You pay once ($29), and it's yours forever. No monthly bills. No one reading your writing. It's like having a helpful writing assistant that lives on your desktop.
        </p>
      </div>
    </div>
  </section>

  <!-- How It Works Section -->
  <section id="how-it-works" class="py-20 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-4">
        <div class="text-xs font-bold uppercase tracking-widest text-[#4B8BD4] mb-3">How It Works</div>
        <h2 class="font-serif text-3xl sm:text-4xl font-bold text-[#1B3A5C] mb-4 leading-tight">Three Simple Steps</h2>
        <p class="text-lg text-[#5A6474] max-w-lg mx-auto">No complicated setup. No technical knowledge required. If you can browse the internet, you can use WorkInPrivate.</p>
      </div>
      <div class="max-w-5xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8 mt-12">
        <!-- Step 1 -->
        <div class="bg-[#F7F9FC] border-2 border-[#E2E8F0] rounded-2xl p-9 text-center hover:border-[#D4E3F5] transition-all" style="box-shadow: none;">
          <div class="w-16 h-16 rounded-full bg-[#EDF2FA] border-2 border-[#D4E3F5] flex items-center justify-center mx-auto mb-5">
            <svg class="w-7 h-7 text-[#4B8BD4]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7,10 12,15 17,10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          </div>
          <div class="text-xs font-bold uppercase tracking-wider text-[#4B8BD4] mb-2.5">Step 1</div>
          <h3 class="font-serif text-lg font-bold text-[#1B3A5C] mb-3">Download the Program</h3>
          <p class="text-[#5A6474] text-base leading-relaxed">Click "Download" and save it to your computer. It works on Windows, Mac, and Linux. Open it and follow the prompts — it walks you through everything step by step.</p>
        </div>
        <!-- Step 2 -->
        <div class="bg-[#F7F9FC] border-2 border-[#E2E8F0] rounded-2xl p-9 text-center hover:border-[#D4E3F5] transition-all">
          <div class="w-16 h-16 rounded-full bg-[#EDF2FA] border-2 border-[#D4E3F5] flex items-center justify-center mx-auto mb-5">
            <svg class="w-7 h-7 text-[#4B8BD4]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          </div>
          <div class="text-xs font-bold uppercase tracking-wider text-[#4B8BD4] mb-2.5">Step 2</div>
          <h3 class="font-serif text-lg font-bold text-[#1B3A5C] mb-3">Type Your Topic</h3>
          <p class="text-[#5A6474] text-base leading-relaxed">Tell the program what you want to write about. For example: "gardening tips for beginners" or "best recipes for Thanksgiving." Just plain English.</p>
        </div>
        <!-- Step 3 -->
        <div class="bg-[#F7F9FC] border-2 border-[#E2E8F0] rounded-2xl p-9 text-center hover:border-[#D4E3F5] transition-all">
          <div class="w-16 h-16 rounded-full bg-[#EDF2FA] border-2 border-[#D4E3F5] flex items-center justify-center mx-auto mb-5">
            <svg class="w-7 h-7 text-[#4B8BD4]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14,2 14,8 20,8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          </div>
          <div class="text-xs font-bold uppercase tracking-wider text-[#4B8BD4] mb-2.5">Step 3</div>
          <h3 class="font-serif text-lg font-bold text-[#1B3A5C] mb-3">Get Your Article</h3>
          <p class="text-[#5A6474] text-base leading-relaxed">In a few minutes, you'll have a complete, well-written article. Copy it into your blog, email, or document. Edit it if you like — it's all yours.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="py-20 bg-[#F7F9FC] border-t-2 border-[#E2E8F0]">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <div class="text-xs font-bold uppercase tracking-widest text-[#4B8BD4] mb-3">Why People Choose WorkInPrivate</div>
        <h2 class="font-serif text-3xl sm:text-4xl font-bold text-[#1B3A5C] leading-tight">Simple, Private, and Affordable</h2>
      </div>
      <div class="max-w-5xl mx-auto grid grid-cols-1 sm:grid-cols-2 gap-6">
        <!-- Feature 1 -->
        <div class="bg-white border-2 border-[#E2E8F0] rounded-xl p-7 flex gap-4 hover:border-[#D4E3F5] transition-colors">
          <div class="w-13 h-13 rounded-xl bg-[#EDF2FA] flex items-center justify-center flex-shrink-0 w-12 h-12">
            <svg class="w-6 h-6 text-[#4B8BD4]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
          </div>
          <div>
            <h3 class="font-bold text-[#1B3A5C] text-base mb-1">Completely Private</h3>
            <p class="text-[#5A6474] text-sm leading-relaxed">Your writing never goes to the internet. It all stays right on your computer, where only you can see it.</p>
          </div>
        </div>
        <!-- Feature 2 -->
        <div class="bg-white border-2 border-[#E2E8F0] rounded-xl p-7 flex gap-4 hover:border-[#D4E3F5] transition-colors">
          <div class="w-12 h-12 rounded-xl bg-[#F0FFF4] flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-[#38A169]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M16 8h-6a2 2 0 000 4h4a2 2 0 010 4H8"/><line x1="12" y1="6" x2="12" y2="8"/><line x1="12" y1="16" x2="12" y2="18"/></svg>
          </div>
          <div>
            <h3 class="font-bold text-[#1B3A5C] text-base mb-1">No Monthly Bills</h3>
            <p class="text-[#5A6474] text-sm leading-relaxed">Pay $29 once and you own it forever. No subscription that keeps charging your credit card month after month.</p>
          </div>
        </div>
        <!-- Feature 3 -->
        <div class="bg-white border-2 border-[#E2E8F0] rounded-xl p-7 flex gap-4 hover:border-[#D4E3F5] transition-colors">
          <div class="w-12 h-12 rounded-xl bg-[#EDF2FA] flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-[#4B8BD4]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          </div>
          <div>
            <h3 class="font-bold text-[#1B3A5C] text-base mb-1">Easy to Use</h3>
            <p class="text-[#5A6474] text-sm leading-relaxed">No programming skills needed. Just open the program, type a topic, and get your article. It's designed to be straightforward.</p>
          </div>
        </div>
        <!-- Feature 4 -->
        <div class="bg-white border-2 border-[#E2E8F0] rounded-xl p-7 flex gap-4 hover:border-[#D4E3F5] transition-colors">
          <div class="w-12 h-12 rounded-xl bg-[#F0FFF4] flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-[#38A169]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
          </div>
          <div>
            <h3 class="font-bold text-[#1B3A5C] text-base mb-1">Works Without Internet</h3>
            <p class="text-[#5A6474] text-sm leading-relaxed">Once it's set up, you don't need to be connected to the internet. Great if your connection is slow or unreliable.</p>
          </div>
        </div>
        <!-- Feature 5 -->
        <div class="bg-white border-2 border-[#E2E8F0] rounded-xl p-7 flex gap-4 hover:border-[#D4E3F5] transition-colors">
          <div class="w-12 h-12 rounded-xl bg-[#EDF2FA] flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-[#4B8BD4]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4-4v2"/><circle cx="9" cy="7" r="4"/></svg>
          </div>
          <div>
            <h3 class="font-bold text-[#1B3A5C] text-base mb-1">No Account Needed</h3>
            <p class="text-[#5A6474] text-sm leading-relaxed">No sign-ups. No passwords to remember. No email address required. Just download and start using it right away.</p>
          </div>
        </div>
        <!-- Feature 6 -->
        <div class="bg-white border-2 border-[#E2E8F0] rounded-xl p-7 flex gap-4 hover:border-[#D4E3F5] transition-colors">
          <div class="w-12 h-12 rounded-xl bg-[#F0FFF4] flex items-center justify-center flex-shrink-0">
            <svg class="w-6 h-6 text-[#38A169]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20V10"/><path d="M18 20V4"/><path d="M6 20v-4"/></svg>
          </div>
          <div>
            <h3 class="font-bold text-[#1B3A5C] text-base mb-1">Helps People Find Your Writing</h3>
            <p class="text-[#5A6474] text-sm leading-relaxed">Every article is written to appear in Google searches (that's called "SEO"). More people will discover your blog or website.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Modules Section -->
  <section class="py-20 bg-white">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <div class="text-xs font-bold uppercase tracking-widest text-[#4B8BD4] mb-3">What It Can Write</div>
        <h2 class="font-serif text-3xl sm:text-4xl font-bold text-[#1B3A5C] mb-4 leading-tight">Seven Types of Content</h2>
        <p class="text-lg text-[#5A6474] max-w-lg mx-auto">Whatever you want to write about, there's probably a writing type for it. Each one is specially designed for its subject.</p>
      </div>
      <div class="max-w-5xl mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        <div class="bg-[#F7F9FC] border-2 border-[#E2E8F0] rounded-xl p-6 flex items-start gap-4 hover:border-[#D4E3F5] transition-colors">
          <div class="w-12 h-12 rounded-xl bg-[#EDF2FA] flex items-center justify-center flex-shrink-0 text-2xl">✍️</div>
          <div>
            <h4 class="font-bold text-[#1B3A5C] text-base mb-1">Blog Writer</h4>
            <p class="text-[#5A6474] text-sm leading-relaxed">Articles for your blog or website, written to attract readers from Google</p>
          </div>
        </div>
        <div class="bg-[#F7F9FC] border-2 border-[#E2E8F0] rounded-xl p-6 flex items-start gap-4 hover:border-[#D4E3F5] transition-colors">
          <div class="w-12 h-12 rounded-xl bg-[#EDF2FA] flex items-center justify-center flex-shrink-0 text-2xl">💼</div>
          <div>
            <h4 class="font-bold text-[#1B3A5C] text-base mb-1">Small Business</h4>
            <p class="text-[#5A6474] text-sm leading-relaxed">Marketing descriptions and content for your business or side project</p>
          </div>
        </div>
        <div class="bg-[#F7F9FC] border-2 border-[#E2E8F0] rounded-xl p-6 flex items-start gap-4 hover:border-[#D4E3F5] transition-colors">
          <div class="w-12 h-12 rounded-xl bg-[#EDF2FA] flex items-center justify-center flex-shrink-0 text-2xl">💰</div>
          <div>
            <h4 class="font-bold text-[#1B3A5C] text-base mb-1">Finance</h4>
            <p class="text-[#5A6474] text-sm leading-relaxed">Articles about money management, investing, and personal finance</p>
          </div>
        </div>
        <div class="bg-[#F7F9FC] border-2 border-[#E2E8F0] rounded-xl p-6 flex items-start gap-4 hover:border-[#D4E3F5] transition-colors">
          <div class="w-12 h-12 rounded-xl bg-[#EDF2FA] flex items-center justify-center flex-shrink-0 text-2xl">🩺</div>
          <div>
            <h4 class="font-bold text-[#1B3A5C] text-base mb-1">Healthcare</h4>
            <p class="text-[#5A6474] text-sm leading-relaxed">Health and wellness articles, medical information guides</p>
          </div>
        </div>
        <div class="bg-[#F7F9FC] border-2 border-[#E2E8F0] rounded-xl p-6 flex items-start gap-4 hover:border-[#D4E3F5] transition-colors">
          <div class="w-12 h-12 rounded-xl bg-[#EDF2FA] flex items-center justify-center flex-shrink-0 text-2xl">📚</div>
          <div>
            <h4 class="font-bold text-[#1B3A5C] text-base mb-1">Academic</h4>
            <p class="text-[#5A6474] text-sm leading-relaxed">Research-style writing for educational topics and in-depth guides</p>
          </div>
        </div>
        <div class="bg-[#F7F9FC] border-2 border-[#E2E8F0] rounded-xl p-6 flex items-start gap-4 hover:border-[#D4E3F5] transition-colors">
          <div class="w-12 h-12 rounded-xl bg-[#EDF2FA] flex items-center justify-center flex-shrink-0 text-2xl">⚖️</div>
          <div>
            <h4 class="font-bold text-[#1B3A5C] text-base mb-1">Legal</h4>
            <p class="text-[#5A6474] text-sm leading-relaxed">Articles about legal topics, policies, and regulatory information</p>
          </div>
        </div>
        <div class="bg-[#F7F9FC] border-2 border-[#E2E8F0] rounded-xl p-6 flex items-start gap-4 hover:border-[#D4E3F5] transition-colors sm:col-span-2 lg:col-span-1">
          <div class="w-12 h-12 rounded-xl bg-[#EDF2FA] flex items-center justify-center flex-shrink-0 text-2xl">💻</div>
          <div>
            <h4 class="font-bold text-[#1B3A5C] text-base mb-1">Tech</h4>
            <p class="text-[#5A6474] text-sm leading-relaxed">Technology guides, how-to articles, and software documentation</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Pricing Section -->
  <section class="py-20 bg-[#EDF2FA] border-t-2 border-[#D4E3F5] text-center">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-xs font-bold uppercase tracking-widest text-[#4B8BD4] mb-3">Pricing</div>
      <h2 class="font-serif text-3xl sm:text-4xl font-bold text-[#1B3A5C] mb-4 leading-tight">One Simple Price. No Surprises.</h2>
      <p class="text-lg text-[#5A6474] max-w-md mx-auto mb-12">Unlike ChatGPT ($20/month) or other AI services, WorkInPrivate is a one-time purchase. Pay once, and it's yours to keep.</p>
      <div class="max-w-md mx-auto bg-white rounded-2xl p-12 border-[3px] border-[#4B8BD4]" style="box-shadow: 0 8px 40px rgba(75,139,212,0.12);">
        <div class="font-serif font-bold text-[#1B3A5C] text-xl mb-2">WorkInPrivate — Complete Package</div>
        <div class="font-serif font-bold text-[#4B8BD4] mb-2" style="font-size: 4.5rem; line-height: 1;"><sup style="font-size: 2rem; vertical-align: super;">$</sup>29</div>
        <div class="text-[#5A6474] font-semibold text-lg mb-2">One-time payment</div>
        <div class="text-[#4B8BD4] font-semibold text-base mb-6">That's it. No hidden fees. No monthly charges.</div>
        <ul class="text-left mb-7 bg-[#F7F9FC] rounded-xl px-5 py-2 border border-[#E2E8F0] list-none space-y-0">
          {[
